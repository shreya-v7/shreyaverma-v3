# --- Public booking (client-safe; Cal.com or your scheduler embed URL) ---
# Example: https://cal.com/yourname/embed or the embed URL Cal gives you
VITE_PUBLIC_BOOKING_EMBED_URL=

# --- Private workspace (omit all Cognito vars on Netlify until AWS is wired; /workspace will 404) ---
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_USER_POOL_CLIENT_ID=
# Group name for admin-only API / Admin tab (create in Cognito → Groups; attach to your user)
VITE_COGNITO_ADMIN_GROUP=admin

# API Gateway base URL for Lambda (must validate Cognito JWT server-side; never put secrets in VITE_*)
VITE_WORKSPACE_API_URL=
